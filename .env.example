# ──────────────────────────────────────────────
# ECOdata - Variaveis de Ambiente
# Copie este arquivo para .env e preencha os valores
# ──────────────────────────────────────────────

# ── BANCO DE DADOS FIREBIRD (OBRIGATORIO) ──
DB_HOST=localhost
DB_PATH=C:\Ecosis\dados\ECODADOS.ECO
DB_USER=SYSDBA
DB_PASSWORD=sua_senha_aqui

# ── SFTP (OBRIGATORIO para envio de arquivos) ──
SFTP_HOST=integracao.tradefy.com.br
SFTP_PORT=2222
SFTP_USER=seu_usuario
SFTP_PASSWORD=sua_senha
SFTP_REMOTE_DIR=/

# ── SEGURANCA SFTP ──
# Fingerprint SHA256 do host SFTP para validacao (opcional, mas recomendado)
# Para obter: ssh-keyscan -p 2222 integracao.tradefy.com.br
SFTP_HOST_KEY=

# ── CORS ──
# Origens permitidas para CORS (separadas por virgula)
CORS_ORIGINS=http://localhost:8580

# ── DADOS DA EMPRESA ──
CNPJ_DISTRIBUIDOR=
CNPJ_INDUSTRIA=
CODIGO_EMPRESA=01

# ── SERVIDOR WEB ──
ECODATA_HOST=0.0.0.0
ECODATA_PORT=8580

# ── NOTIFICACAO (opcional) ──
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
NOTIFY_EMAILS=
